NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_)
# Get this from: Supabase Dashboard → Project Settings → API → service_role (secret)
# This bypasses RLS and is used exclusively inside /api/* routes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

NVIDIA_API_KEY=your_nvidia_api_key

# Firebase Admin SDK (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_)
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single-line string (escape any quotes if needed)
FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
